                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Fecha: " + new java.text.SimpleDateFormat("dd-MM-yyyy").format($F{fecha_boleta})]]></textFieldExpression>
            </textField>
            <textField>
