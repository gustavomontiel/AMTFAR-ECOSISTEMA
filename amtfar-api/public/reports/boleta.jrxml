<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BoletaDeposito" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="e3b5e4c6-8f2c-4712-98c5-1b059db5b4f2">
    
    <subDataset name="ConceptosDataset" uuid="3d8dc9f0-d5a2-4a0b-8d1d-0f5a9e3bc8f1">
        <parameter name="IdBoletaDS" class="java.lang.Integer"/>
        <queryString>
            <![CDATA[SELECT descripcion_historica, importe_calculado FROM boletas_conceptos WHERE boleta_id = $P{IdBoletaDS} AND importe_calculado > 0 ORDER BY id]]>
        </queryString>
        <field name="descripcion_historica" class="java.lang.String"/>
        <field name="importe_calculado" class="java.lang.Double"/>
    </subDataset>

    <parameter name="IdBoleta" class="java.lang.Integer"/>
    <parameter name="IdFarmacia" class="java.lang.Integer"/>

    <queryString>
        <![CDATA[
            SELECT 
                b.id,
                b.periodo_id,
                b.fecha_boleta,
                b.fecha_vto,
                b.total_deposito,
                f.razon_social,
                f.cuit,
                f.direccion AS domicilio,
                IFNULL(l.nombre, 'Misiones') AS localidad_nombre,
                'Consumidor Final / Exento' AS tipo_contribuyente,
                CONCAT(
                    '01251',
                    LPAD(CAST(b.id AS CHAR), 10, '0'),
                    DATE_FORMAT(IFNULL(b.fecha_vto, CURDATE()), '%y%m%d'),
                    LPAD(REPLACE(CAST(IFNULL(b.total_deposito,0) AS CHAR), '.', ''), 8, '0'),
                    '0000000'
                ) AS CodigoBarras
            FROM boletas b
            LEFT JOIN farmacias f ON b.farmacia_id = f.id
            LEFT JOIN localidades l ON f.localidad_id = l.id
            WHERE b.id = $P{IdBoleta} AND b.farmacia_id = $P{IdFarmacia}
        ]]>
    </queryString>
    <field name="id" class="java.lang.Integer"/>
    <field name="periodo_id" class="java.lang.String"/>
    <field name="fecha_boleta" class="java.sql.Date"/>
    <field name="fecha_vto" class="java.sql.Date"/>
    <field name="total_deposito" class="java.lang.Double"/>
    <field name="razon_social" class="java.lang.String"/>
    <field name="cuit" class="java.lang.String"/>
    <field name="domicilio" class="java.lang.String"/>
    <field name="localidad_nombre" class="java.lang.String"/>
    <field name="tipo_contribuyente" class="java.lang.String"/>
    <field name="CodigoBarras" class="java.lang.String"/>
    
    <detail>
        <band height="260">
            <!-- RECUADRO PRINCIPAL (TALON) -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="250" uuid="8d48d6f1-b4a0-40dd-bfff-8a538a778a82"/>
