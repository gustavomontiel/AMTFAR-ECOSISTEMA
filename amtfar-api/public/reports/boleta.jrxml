                <textElement><font size="11" isItalic="true" isBold="true"/></textElement>
                <text><![CDATA[CUPÓN DE PAGO]]></text>
            </staticText>
            <textField>
                <reportElement x="400" y="45" width="150" height="15" uuid="b021733c-1fbf-4623-b6b9-8c89a9eaee29"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Nro.: " + String.format("%08d", $F{id})]]></textFieldExpression>
            </textField>
            <textField>
